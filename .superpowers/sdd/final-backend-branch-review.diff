+/** @return list<string> */
+function dashboardGraphJsonStrings(mixed $value): array
+{
+    if (is_string($value)) {
+        return [$value];
+    }
+    if (! is_array($value)) {
+        return [];
+    }
+
+    $strings = [];
+    foreach ($value as $child) {
+        array_push($strings, ...dashboardGraphJsonStrings($child));
+    }
+
+    return $strings;
+}
