+function canonicalGraphForImportContext(array $context): array
+{
+    $projectId = DB::table('artifacts')->where('id', $context['artifact_id'])->value('project_id');
+    $canonical = app(CanonicalGraphRepository::class)->findByIdentity(
+        $projectId,
+        'repository',
