+
+            return [];
+        }
+    };
+
+    try {
+        app(GenesisGraphImportService::class)->importGenesis($context['import_id'], $client, 'fake', false);
+    } catch (Throwable $exception) {
+        return $exception;
+    }
+
+    throw new RuntimeException('Expected the canonical projection to fail.');
+}
