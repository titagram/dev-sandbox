+function dashboardGraphLooksLikeLocalPath(string $value): bool
+{
+    $trimmed = trim($value);
+
+    return str_starts_with(strtolower($trimmed), 'file://')
+        || str_starts_with($trimmed, '/')
+        || preg_match('/^[a-z]:[\\\\\/]/i', $trimmed) === 1
+        || str_starts_with($trimmed, '\\\\');
+}
