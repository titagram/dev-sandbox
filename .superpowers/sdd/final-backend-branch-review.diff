+/** @return array<string, string> */
+function dashboardGraphSemanticNodeIdMap(array $response): array
+{
+    $map = [];
+    foreach ($response['nodes'] as $node) {
+        $map[(string) $node['label']] = (string) $node['id'];
+    }
+    ksort($map);
+
+    return $map;
+}
