{
  "openapi": "3.1.0",
  "info": {
    "title": "Hades Backend API",
    "version": "v1"
  },
  "paths": {
    "/api/hades/v1/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Public health response"
          }
        }
      }
    },
    "/api/hades/v1/token/verify": {
      "post": {
        "requestBody": {
          "required": true
        },
        "responses": {
          "200": {
            "description": "Bootstrap token is valid"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/hades/v1/agents/register": {
      "post": {
        "requestBody": {
          "required": true
        },
        "responses": {
          "200": {
            "description": "Agent registered and derived token issued"
          }
        }
      }
    },
    "/api/hades/v1/capabilities": {
      "get": {
        "summary": "Discover authenticated Hades protocol capabilities",
        "description": "Requires an authenticated Hades agent token. `persephone_agent_queue_v1` advertises protocol support only; it is not a per-agent permission to mutate data.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Authenticated capability discovery",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilitiesResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/hades/v1/workspaces/bind": {
      "post": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true
        },
        "responses": {
          "200": {
            "description": "Workspace binding"
          }
        }
      }
    },
    "/api/hades/v1/workspaces/{workspaceBinding}/unlink": {
      "post": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "workspaceBinding",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Workspace unlinked"
          }
        }
      }
    },
    "/api/hades/v1/memory/snapshot": {
      "get": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Versioned shared memory snapshot"
          }
        }
      }
    },
    "/api/hades/v1/memory/proposals": {
      "post": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true
        },
        "responses": {
          "200": {
            "description": "Memory proposal accepted, pending, refused, or conflicted"
          }
        }
      }
    },
    "/api/hades/v1/agent/jobs": {
      "get": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Queued jobs for this agent/workspace"
          }
        }
      }
    },
    "/api/hades/v1/agent/jobs/{job}/status": {
      "post": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true
          }
        ],
        "requestBody": {
          "required": true
        },
        "responses": {
          "200": {
            "description": "Job status transition recorded"
          }
        }
      }
    },
    "/api/hades/v1/agent/jobs/{job}/result": {
      "post": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true
          }
        ],
        "requestBody": {
          "required": true
        },
        "responses": {
          "200": {
            "description": "Bounded job result stored"
          }
        }
      }
    },
    "/api/hades/v1/artifacts": {
      "post": {
        "summary": "Upload a bounded Hades artifact for a linked workspace",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArtifactUploadRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Artifact stored"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/hades/v1/graph/traverse": {
      "get": {
        "summary": "Traverse the backend-selected canonical graph projection for one linked workspace",
        "description": "The workspace binding is the exact source scope. Clients cannot submit or select graph_version; the backend selects the latest verified ready projection. Response graph metadata is additive to the existing Hades traversal envelope.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_binding_id",
            "in": "query",
            "required": true,
            "description": "Linked workspace binding that defines the exact workspace_binding source scope.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 1000
            }
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "any",
                "out",
                "in"
              ],
              "default": "any"
            }
          },
          {
            "name": "max_depth",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3,
              "default": 2
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bounded traversal of the current verified projection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CanonicalGraphTraverseResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "description": "project_mismatch: the authenticated Hades agent belongs to another project.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HadesStructuredErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "workspace_binding_not_found, graph_scope_not_found, graph_projection_not_ready, or query_error. A not-ready projection is not an empty graph.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HadesStructuredErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "workspace_binding_unlinked: the binding exists but is not linked.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HadesStructuredErrorResponse"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/api/hades/v1/doctor/reports": {
      "post": {
        "summary": "Submit an explicit Hades doctor report",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DoctorReportRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Doctor report stored"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/hades/v1/persephone/inbox": {
      "get": {
        "summary": "Poll the persistent Persephone inbox",
        "description": "Returns at most 100 oldest-first, non-expired messages for the authenticated target agent. The cursor is an opaque server ULID scoped to the same project and target. A workspace filter returns unbound messages and messages for exactly the authenticated target's active binding. Polling does not mark messages read. Cross-project and wrong-target requests are denied without a foreign-record existence oracle.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "target_agent_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "target_workspace_binding_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Inbox events and the last returned or input cursor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersephoneInboxResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/PersephoneError"
          },
          "404": {
            "$ref": "#/components/responses/PersephoneError"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/api/hades/v1/persephone/events": {
      "get": {
        "summary": "Read Persephone inbox events as a bounded SSE stream",
        "description": "Uses the exact inbox authorization, validation, expiry, workspace filter, cursor, ordering, and limit semantics. The response is bounded, never an infinite PHP worker: each message is one SSE block with `id`, `event: message`, and one-line JSON data containing exactly the 15-field envelope plus `id`, followed by `event: stop` with `{\"reason\":\"bounded\",\"cursor\":...}`. Polling is the fallback transport.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "target_agent_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "target_workspace_binding_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bounded SSE response with message blocks followed by a stop block",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                },
                "example": "id: 01J00000000000000000000000\nevent: message\ndata: {\"schema\":\"hades.persephone.agent-message.v1\",\"message_id\":\"message-1\",\"correlation_id\":\"correlation-1\",\"project_id\":\"project-1\",\"sender_agent_id\":\"sender-1\",\"target_agent_id\":\"target-1\",\"target_workspace_binding_id\":null,\"message_type\":\"information_request\",\"effect\":\"information_read\",\"capability\":\"status_query\",\"expires_at\":4102444800,\"payload\":{},\"causation_id\":null,\"remote_task_id\":null,\"remote_task_version\":null,\"id\":\"01J00000000000000000000000\"}\n\nevent: stop\ndata: {\"reason\":\"bounded\",\"cursor\":\"01J00000000000000000000000\"}\n\n"
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/PersephoneError"
          },
          "404": {
            "$ref": "#/components/responses/PersephoneError"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/api/hades/v1/persephone/messages": {
      "post": {
        "summary": "Create a project-scoped Persephone agent message",
        "description": "Accepts only the strict hades.persephone.agent-message.v1 envelope. Required strings are trimmed and non-blank; nullable identifiers are null or trimmed non-blank strings; expires_at is a future Unix timestamp; payload is a JSON object with at most 128 top-level properties and at most 65,536 bytes after canonical compact sorted UTF-8 encoding. The sender token, project, active target agent, and optional active target binding must all agree. Unknown top-level fields are rejected. A first write returns 201, an identical normalized replay returns 200, and a conflicting normalized envelope with the same project_id and message_id returns 409. The transport stores and returns the envelope without deriving authority from payload fields; legacy hades_persephone_events rows are isolated.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersephoneAgentMessageEnvelope"
                }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message stored for the first time",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersephoneMessageResponse"
                }
              }
            }
          },
          "200": {
            "description": "Identical normalized message replay",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersephoneMessageResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          },
          "403": {
            "$ref": "#/components/responses/PersephoneError"
          },
          "404": {
            "$ref": "#/components/responses/PersephoneError"
          },
          "409": {
            "$ref": "#/components/responses/PersephoneError"
          }
        }
      }
    },
    "/api/hades/v1/evidence-packs": {
      "get": {
        "summary": "Search Hades evidence packs for a linked workspace",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Ranked evidence pack results"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      },
      "post": {
        "summary": "Store a Hades evidence pack for source-free diagnosis",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true
        },
        "responses": {
          "201": {
            "description": "Evidence pack stored"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "responses": {
      "Error": {
        "description": "Hades API error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication failed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/PersephoneErrorResponse"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Request validation failed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/PersephoneErrorResponse"
            }
          }
        }
      },
      "PersephoneError": {
        "description": "Persephone queue authorization, cursor, binding, or idempotency error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/PersephoneErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ArtifactUploadRequest": {
        "type": "object",
        "required": [
          "project_id",
          "workspace_binding_id",
          "schema",
          "artifact"
        ],
        "properties": {
          "project_id": {
            "type": "string"
          },
          "agent_id": {
            "type": "string"
          },
          "workspace_binding_id": {
            "type": "string"
          },
          "job_id": {
            "type": "string"
          },
          "schema": {
            "type": "string",
            "enum": [
              "hades.git_tree.v1",
              "hades.symbols.v1",
              "hades.php_graph.v1",
              "hades.code_graph.v1"
            ]
          },
          "artifact": {
            "type": "object",
            "description": "For hades.php_graph.v1 and hades.code_graph.v1, graph_contract is additive and the legacy schema name remains valid.",
            "properties": {
              "graph_contract": {
                "$ref": "#/components/schemas/CanonicalGraphArtifactContract"
              }
            },
            "additionalProperties": true
          },
          "sha256": {
            "type": "string"
          },
          "truncated": {
            "type": "boolean"
          },
          "redactions": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "CanonicalGraphArtifactContract": {
        "type": "object",
        "required": [
          "version",
          "extractor",
          "coverage",
          "source"
        ],
        "properties": {
          "version": {
            "type": "string",
            "const": "hades.graph_artifact.v1"
          },
          "extractor": {
            "type": "object",
            "required": [
              "name",
              "version",
              "mode",
              "quality",
              "fallback_reason"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "mode": {
                "type": "string",
                "enum": [
                  "native",
                  "graphify",
                  "fallback",
                  "legacy_adapter"
                ]
              },
              "quality": {
                "type": "string",
                "enum": [
                  "full",
                  "partial",
                  "inventory_only"
                ]
              },
              "fallback_reason": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1,
                "description": "Bounded machine-readable reason. Graphify failures use graphify_failed:<ExceptionClass>; raw exception messages and absolute paths are forbidden."
              }
            },
            "additionalProperties": false
          },
          "coverage": {
            "type": "object",
            "required": [
              "languages",
              "files_total",
              "files_analyzed",
              "files_failed"
            ],
            "properties": {
              "languages": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "files_total": {
                "type": "integer",
                "minimum": 0
              },
              "files_analyzed": {
                "type": "integer",
                "minimum": 0
              },
              "files_failed": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "source": {
            "type": "object",
            "required": [
              "branch",
              "head_commit"
            ],
            "properties": {
              "branch": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "head_commit": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "CanonicalGraphTraverseResponse": {
        "type": "object",
        "required": [
          "protocol_version",
          "project_id",
          "workspace_binding_id",
          "version",
          "etag",
          "projection_id",
          "artifact_id",
          "schema",
          "graph_version",
          "head_commit",
          "start",
          "direction",
          "max_depth",
          "limit",
          "quality",
          "count",
          "edge_count",
          "truncated",
          "match_fields",
          "freshness",
          "nodes",
          "edges",
          "provenance",
          "server_time"
        ],
        "properties": {
          "protocol_version": {
            "type": "string",
            "const": "v1"
          },
          "project_id": {
            "type": "string"
          },
          "workspace_binding_id": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "description": "Traversal result version derived from graph_version and bounded query inputs."
          },
          "etag": {
            "type": "string"
          },
          "projection_id": {
            "type": "string"
          },
          "artifact_id": {
            "type": "string"
          },
          "schema": {
            "type": "string",
            "enum": [
              "hades.php_graph.v1",
              "hades.code_graph.v1"
            ]
          },
          "graph_version": {
            "type": "string",
            "description": "Backend-selected verified projection version; this is response-only."
          },
          "head_commit": {
            "type": [
              "string",
              "null"
            ]
          },
          "quality": {
            "type": "string",
            "enum": [
              "full",
              "partial",
              "inventory_only"
            ]
          },
          "start": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": [
              "any",
              "out",
              "in"
            ]
          },
          "max_depth": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          },
          "limit": {
